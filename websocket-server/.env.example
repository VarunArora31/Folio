# ── Server ────────────────────────────────────────────────────────────────────
PORT=1234

# ── Neon Database ─────────────────────────────────────────────────────────────
# Same DATABASE_URL you use in your Next.js app
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Clerk ─────────────────────────────────────────────────────────────────────
# From Clerk dashboard → API Keys → Secret key
CLERK_SECRET_KEY=sk_live_...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (comma-separated if multiple)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Persistence ───────────────────────────────────────────────────────────────
# How many Y.js updates to buffer before saving to DB
PERSISTENCE_DEBOUNCE_MS=5000
# Maximum time between forced saves (even if updates keep coming)
PERSISTENCE_MAX_INTERVAL_MS=30000
